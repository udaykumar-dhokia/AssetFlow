# ============================================================
# AssetFlow Frontend — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit secrets.
# ============================================================

# ── API ──────────────────────────────────────────────────────
# Dev: leave as /api — Vite proxy forwards to SOCKET_URL host
# Prod: https://your-api-domain.com/api
VITE_API_BASE_URL=/api

# ── Socket.IO ────────────────────────────────────────────────
# Dev: local backend
# Prod: https://your-api-domain.com
VITE_SOCKET_URL=http://localhost:8000

# ── App ──────────────────────────────────────────────────────
VITE_APP_NAME=AssetFlow
VITE_APP_VERSION=1.0.0

# ── Authentication (OAuth/SSO) ───────────────────────────────
VITE_CLIENT_ID=
VITE_CLIENT_SECRET=
